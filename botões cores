import tkinter as tk 
 
root = tk.Tk()
root.title("Janela 1")
root.geometry("200x200")

def change_verde():
    verde = "#00ff04"
    root.configure(bg=verde)
 
branco = "#ffffff"
root.configure(bg=branco)

button1 = tk.Button(text="verde", command=change_verde)
button1.place(x=50, y=50)

root.mainloop()